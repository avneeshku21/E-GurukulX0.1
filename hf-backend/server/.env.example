# EduTrack server environment variables
# Copy to backend/.env or your deployment secret store.

PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="mongodb+srv://username:password@cluster0.example.mongodb.net/edutrack?retryWrites=true&w=majority"

# JWT / auth
JWT_SECRET="replace-with-a-32-char-secret"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# Frontend URL used in emails, redirects, and CORS.
# Local development:
VITE_APP_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Production behind Nginx + Certbot:
# VITE_APP_URL="https://example.com"
# ALLOWED_ORIGINS="https://example.com,https://www.example.com"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# YouTube Data API v3
# Kept with the current name because backend/services/youtube.service.js reads this exact key.
VITE_YOUTUBE_API_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""