# Copy to backend/.env for Docker Compose production runs.

PORT=8080
NODE_ENV=production

# Database
DATABASE_URL="mongodb+srv://username:password@cluster0.example.mongodb.net/edutrack?retryWrites=true&w=majority"

# JWT / auth
JWT_SECRET="replace-with-a-32-char-secret"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# Public app URL and allowed frontend origins
VITE_APP_URL="https://example.com"
ALLOWED_ORIGINS="https://example.com,https://www.example.com"

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# YouTube Data API v3
VITE_YOUTUBE_API_KEY=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""